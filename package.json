{
  "name": "cyvx",
  "version": "7.0.0",
  "private": true,
  "type": "commonjs",
  "description": "Spark + CYVX autonomous production reality infrastructure",
  "scripts": {
    "start": "node ./api/runtime-v7.js",
    "dev": "node ./api/runtime-v7.js",
    "public": "node ./api/runtime-v7.js",
    "public:core": "node ./api/public.js",
    "public:test": "node --test ./test/public-runtime.test.js",
    "api": "node ./api/production.js",
    "cli": "node ./cli/cyvx.js",
    "build": "node ./scripts/build-v7.js",
    "serve": "node ./ui/server.js",
    "test": "node --test",
    "test:ops": "node --test ./test/runtime-supervisor.test.js ./test/ops-overview.test.js",
    "test:ui": "node --test ./test/ui-contract.test.js",
    "verify": "npm run verify:production",
    "verify:production": "node --check ./api/runtime-v7.js && node --check ./core/production/autonomy_supervisor.js && node --check ./core/ops/overview.js && npm test && npm run build",
    "github:test": "node --test ./test/github-control-plane.test.js ./test/github-control-plane-advanced.test.js",
    "spark": "node ./spark/server.js",
    "spark:start": "bash ./spark/start.sh",
    "spark:verify": "node --test ./test/spark-runtime.test.js ./test/spark-server.test.js ./test/spark-security.test.js",
    "spark:run": "bash ./spark/start.sh",
    "spark:test": "node --test ./test/spark-runtime.test.js ./test/spark-server.test.js ./test/spark-security.test.js",
    "partner": "node ./scripts/cyvx-partner-cli.js",
    "strategy": "node scripts/cyvx-operating-loop.js",
    "cyvx": "node scripts/cyvx-operating-loop.js",
    "agency:loop": "node scripts/cyvx-agency-loop.js",
    "agency:tick": "node scripts/cyvx-agency-daemon.js",
    "agency:daemon": "node scripts/cyvx-agency-daemon.js start",
    "wiki:generate": "node --check ./scripts/generate-wiki-v2.js && node ./scripts/generate-wiki-v2.js ./dist/wiki",
    "wiki:publish": "bash ./scripts/publish-wiki.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "ws": "^8.21.0"
  }
}
