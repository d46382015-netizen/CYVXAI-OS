# Spark + CYVX v7 production runtime
NODE_ENV=production
PORT=3000
CYVX_PUBLIC_HOST=0.0.0.0
CYVX_GATEWAY_INTERNAL_PORT=3001
CYVX_INTERNAL_PORT=3002
CYVX_SPARK_INTERNAL_PORT=3003
CYVX_CONTROL_PORT=3004

# Durable legacy storage
CYVX_DATA_ROOT=/var/lib/cyvx
CYVX_PLATFORM_STATE=/var/lib/cyvx/platform-state.json
SPARK_STATE_FILE=/var/lib/cyvx/spark-state.json
SPARK_ARTIFACT_ROOT=/var/lib/cyvx/worlds
SPARK_LOG=/var/lib/cyvx/logs/spark-runtime.log
CYVX_GITHUB_WEBHOOK_STORE=/var/lib/cyvx/github-webhooks.json
CYVX_GITHUB_AUTH_STORE=/var/lib/cyvx/github-auth.json

# Bounded execution
CYVX_AUTONOMY=1
CYVX_AUTONOMY_INTERVAL_MS=3000
CYVX_AUTONOMY_MAX_PER_TICK=10

# Public and operator security
APP_BASE_URL=https://example.com
CYVX_API_KEY=replace-with-32-plus-random-characters
CYVX_OWNER_ID=replace-with-owner-id
CYVX_OPERATOR_SESSION_SECRET=replace-with-32-plus-random-characters

# Reliable multi-tenant SaaS service
CYVX_SAAS_HOST=0.0.0.0
CYVX_SAAS_PORT=3300
CYVX_STORE=postgres_rest
CYVX_POSTGREST_URL=https://your-project.supabase.co
CYVX_POSTGREST_SERVICE_KEY=replace-with-managed-service-role-secret
CYVX_POSTGREST_SCHEMA=public
CYVX_POSTGREST_TIMEOUT_MS=10000
CYVX_OIDC_ISSUER=https://identity.example.com/
CYVX_OIDC_AUDIENCE=cyvx-saas
CYVX_OIDC_JWKS_URL=https://identity.example.com/.well-known/jwks.json
CYVX_REQUIRE_MFA_FOR_PRIVILEGED=1
CYVX_STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
CYVX_STRIPE_PRICE_PLANS={"price_starter":"starter","price_growth":"growth","price_enterprise":"enterprise"}

# GitHub App integration
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY_PEM=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_STATE_SECRET=
GITHUB_TOKEN_ENCRYPTION_KEY=
